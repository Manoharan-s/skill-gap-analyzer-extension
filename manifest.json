{
  "manifest_version":3,
  "name":"Skill Gap Analyser",
  "version":"1.0",
  "description":"Compare Skills With Linkedin Profile and Jobs",
  "permissions":["activeTab","tabs","storage"],
  "host_permissions":[
    "<all_urls>"
  ],
   "action": {
    "default_popup":"popup.html"
  },
  "content_scripts":[{
    "matches":["<all_urls>"],
     "js": ["content.js"]
  }]






}