{
  "manifest_version":3,
  "name":"Skill Gap Analyser",
  "version":"1.0",
  "description":"Compare Skills With Linkedin Profile and Jobs",
  "permissions":["activeTab","tabs","storage"],
  "host_permissions":[
    "https://www.linkedin.com/*"
  ],
   "action": {
    "default_popup":"popup.html"
  },
  "content_scripts":[{
    "matches":["https://www.linkedin.com/*"],
     "js": ["content.js"]
  }]






}